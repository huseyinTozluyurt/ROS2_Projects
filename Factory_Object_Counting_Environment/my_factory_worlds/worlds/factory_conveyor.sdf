    <!-- Moving products with closer spacing (about half the previous gap)
         and more realistic non-cylindrical item shapes.
         All items keep the same commanded speed, then fall into the lower box. -->

    <model name="shipping_box_large">
      <static>false</static>
      <self_collide>false</self_collide>
      <pose>-9.6 0.00 1.505 0 0 0</pose>
      <plugin filename="gz-sim-velocity-control-system" name="gz::sim::systems::VelocityControl">
        <initial_linear>0.18 0 0</initial_linear>
      </plugin>
      <link name="link">
        <gravity>true</gravity>
        <velocity_decay><linear>0.0</linear><angular>8.0</angular></velocity_decay>
        <inertial><mass>0.55</mass><inertia><ixx>0.010</ixx><iyy>0.010</iyy><izz>0.010</izz></inertia></inertial>
        <collision name="collision">
