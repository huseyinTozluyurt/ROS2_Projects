              <length>1.10</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Support legs -->
    <model name="leg_1"><static>true</static><pose>-9.0 0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>
    <model name="leg_2"><static>true</static><pose>-9.0 -0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>
    <model name="leg_3"><static>true</static><pose>-4.5 0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>
    <model name="leg_4"><static>true</static><pose>-4.5 -0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>
    <model name="leg_5"><static>true</static><pose>0.0 0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>
    <model name="leg_6"><static>true</static><pose>0.0 -0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>
    <model name="leg_7"><static>true</static><pose>4.5 0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>
    <model name="leg_8"><static>true</static><pose>4.5 -0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>
    <model name="leg_9"><static>true</static><pose>9.0 0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>
    <model name="leg_10"><static>true</static><pose>9.0 -0.70 0.65 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.12 0.12 1.30</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.12 0.12 1.30</size></box></geometry><material><ambient>0.45 0.45 0.45 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material></visual></link></model>

    <!-- Wider and longer open-top collection box placed at a clearly lower height than the elevated conveyor so objects drop into it and remain collected. -->
    <!-- Transfer shelf removed so objects leave the conveyor and fall by gravity directly into the lower box. -->


    <model name="collection_box_bottom">
      <static>true</static>
      <pose>13.60 0 0.06 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>5.8 4.2 0.12</size></box></geometry><surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction><bounce><restitution_coefficient>0.0</restitution_coefficient></bounce></surface></collision>
        <visual name="visual"><geometry><box><size>5.8 4.2 0.12</size></box></geometry><material><ambient>0.20 0.22 0.28 1</ambient><diffuse>0.20 0.22 0.28 1</diffuse></material></visual>
      </link>
    </model>

    <model name="collection_box_left_wall">
      <static>true</static>
      <pose>13.60 2.04 0.95 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>5.8 0.12 1.90</size></box></geometry><surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction><bounce><restitution_coefficient>0.0</restitution_coefficient></bounce></surface></collision>
        <visual name="visual"><geometry><box><size>5.8 0.12 1.90</size></box></geometry><material><ambient>0.28 0.30 0.36 1</ambient><diffuse>0.28 0.30 0.36 1</diffuse></material></visual>
      </link>
    </model>

    <model name="collection_box_right_wall">
      <static>true</static>
      <pose>13.60 -2.04 0.95 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>5.8 0.12 1.90</size></box></geometry><surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction><bounce><restitution_coefficient>0.0</restitution_coefficient></bounce></surface></collision>
        <visual name="visual"><geometry><box><size>5.8 0.12 1.90</size></box></geometry><material><ambient>0.28 0.30 0.36 1</ambient><diffuse>0.28 0.30 0.36 1</diffuse></material></visual>
      </link>
    </model>




    <model name="collection_box_back_wall">
